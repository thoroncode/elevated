default_platform(:ios)

platform :appletv do
  desc "Stamp version, build archive, and upload to App Store Connect"
  lane :release do
    # Stamp date-based version
    sh("cd .. && ./stamp-version.sh")

    # Archive unsigned (no tvOS devices registered for dev signing)
    sh("cd .. && xcodebuild -project ElevatedTV.xcodeproj -scheme Elevated " \
       "-destination 'generic/platform=tvOS' -configuration Release " \
       "archive -archivePath /tmp/ElevatedTV.xcarchive " \
       "-allowProvisioningUpdates " \
       "CODE_SIGN_IDENTITY='-' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO")

    # Export with distribution signing and upload directly
    sh("cd .. && rm -rf /tmp/ElevatedTVExport && xcodebuild -exportArchive " \
       "-archivePath /tmp/ElevatedTV.xcarchive " \
       "-exportOptionsPlist ExportOptionsTV.plist " \
       "-exportPath /tmp/ElevatedTVExport " \
       "-allowProvisioningUpdates")
  end

  desc "Submit the latest TestFlight build for App Store review"
  lane :submit do
    deliver(
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      platform: "appletvos",
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end

platform :ios do
  desc "Stamp version, build archive, and upload to TestFlight"
  lane :release do
    # Stamp date-based version
    sh("cd .. && ./stamp-version.sh")

    # Build archive
    build_app(
      project: "ElevatedIOS.xcodeproj",
      scheme: "Elevated",
      configuration: "Release",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      export_team_id: "MU8NPY2D99",
      clean: true
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload metadata and screenshots to App Store Connect"
  lane :metadata do
    # Upload screenshots only (metadata upload crashes on new apps
    # due to missing AppStoreReviewDetail — known Fastlane bug)
    deliver(
      skip_binary_upload: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      skip_metadata: true,
      force: true,
      platform: "ios",
      pkg: nil,
      ipa: nil
    )
    UI.success("Screenshots uploaded. Text metadata must be set in App Store Connect until Fastlane fixes the 'No data' bug for new apps.")
  end

  desc "Submit the latest TestFlight build for App Store review"
  lane :submit do
    deliver(
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end


  desc "Generate App Store screenshots from the demo"
  lane :screenshots do
    sh("cd .. && make ios-screenshots")
  end
end
